{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },

    { "src": "/api/(.*)", "dest": "/api/$1" },

    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ]
}
